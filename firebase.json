{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "redirects": [
      { "source": "/shape", "destination": "/wheel/shape", "type": 301 },
      { "source": "/shape/**", "destination": "/wheel/shape", "type": 301 },
      { "source": "/fraction", "destination": "/wheel/fraction", "type": 301 },
      { "source": "/fraction/**", "destination": "/wheel/fraction", "type": 301 },
      { "source": "/sponge", "destination": "/wheel/slowpoke", "type": 301 },
      { "source": "/sponge/**", "destination": "/wheel/slowpoke", "type": 301 }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
