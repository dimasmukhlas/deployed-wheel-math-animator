rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "dimasmukhlas@gmail.com";
    }

    // Public-read cover images; only admin can write.
    match /covers/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default: deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

